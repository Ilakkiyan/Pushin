{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pushin",
  "version": "0.6.3",
  "identifier": "com.pushin.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Pushin",
        "width": 1280,
        "height": 820,
        "minWidth": 940,
        "minHeight": 640,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQzRDQxMEFCRDk2MzdGQzQKUldURWYyUFpxeERVMHhLNkErNjgvQmQyd1dlMXFWQ0ZvZGJJTGRoS3dlZ0tUN2orSEhzMUVrZmUK",
      "endpoints": [
        "https://github.com/Ilakkiyan/Pushin/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
